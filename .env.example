# Copy to .env and adjust before running docker-compose.prod.yml
# Generate JWT keys: scripts/generate-jwt-keys.ps1 (Windows) or scripts/generate-jwt-keys.sh (Linux/macOS)

POSTGRES_DB=resos
POSTGRES_USER=resos
POSTGRES_PASSWORD=change_me_in_production

SPRING_DATASOURCE_USERNAME=resos
SPRING_DATASOURCE_PASSWORD=change_me_in_production

REDIS_HOST=redis
REDIS_PORT=6379

# PEM contents on a single line or use docker secrets in production
RESOS_JWT_PRIVATE_KEY=
RESOS_JWT_PUBLIC_KEY=

# Comma-separated origins allowed by the API (must include the frontend URL)
RESOS_CORS_ALLOWED_ORIGINS=http://localhost
